<parameter name="content">#!/usr/bin/env python3
"""
Instagram DM Bot - Auto-detects Safari, no keypress needed
"""

import pyautogui
import time
import random
import cv2
import numpy as np
import mss
import pytesseract
import requests


OLLAMA_ENDPOINT = "http://localhost:11434/api/generate"
OLLAMA_MODEL = "mistral"
SYSTEM_PROMPT = """You are a friendly Instagram DM assistant. Reply briefly (under 150 chars)."""
CHECK_INTERVAL = 2

safari_left = safari_top = safari_right = safari_bottom = None


def human_delay(min_s=0.3, max_s=0.8):
    time.sleep(random.uniform(min_s, max_s))


def type_human(text):
    for char in text:
        if len(char) == 1 and char.isalnum():
            pyautogui.press(char)
        else:
            pyautogui.write(char)
        time.sleep(random.uniform(0.03, 0.07))


def auto_detect_safari():
    """Automatically detect Safari window by looking for browser UI."""
    with mss.mss() as sct:
        monitor = sct.monitors[1]
        screenshot = np.array(sct.grab(monitor))
        h, w = screenshot.shape[:2]
        
        # Look for Safari red traffic light button (top left of window)
        gray = cv2.cvtColor(screenshot, cv2.COLOR_BGR2GRAY)
        
        data = pytesseract.image_to_data(gray, output_type=pytesseract.Output.DICT)
        
        for i, text in enumerate(data['text']):
            text_lower = text.lower().strip()
            conf = float(data['conf'][i]) if data['conf'][i] != '-1' else 0
            
            if conf > 40 and 'safari' in text_lower:
                x = data['left'][i] + data['width'][i] // 2
                y = data['top'][i] + data['height'][i] // 2
                return (x, y, w, h)
        
        return None


def setup_safari_position():
    global safari_left, safari_top, safari_right, safari_bottom
    
    print("\n" + "=" * 60)
    print("DETECTING SAFARI WINDOW...")
    print("=" * 60)
    
    # Try auto-detection first
    safari_pos = auto_detect_safari()
    
    if safari_pos:
        print(f"✓ Found Safari at position: {safari_pos}")
        sx, sy, sw, sh = safari_pos
    else:
        print("Click anywhere inside Safari window...")
        # Wait for click, then auto-start
        last_pos = pyautogui.position()
        while True:
            current_pos = pyautogui.position()
            if current_pos != last_pos:
                print(f"   Clicked at: {current_pos}")
                sx, sy = current_pos[0], current_pos[1]
                sw, sh = 800, 600  # Default Safari size
                break
            last_pos = current_pos
            time.sleep(0.1)
    
    # Set Safari capture area (assume click is in center of window)
    safari_left = max(0, sx - 400)
    safari_top = max(0, sy - 300)
    safari_right = min(1920, sx + 400)
    safari_bottom = min(1080, sy + 300)
    
    print(f"✓ Capture area: ({safari_left}, {safari_top}) to ({safari_right}, {safari_bottom})")
    print(f"✓ Bot starting automatically - watching for messages!\n")


def capture_safari():
    if safari_left is None:
        return None
    with mss.mss() as sct:
        screenshot = np.array(sct.grab(sct.monitors[1]))
        return screenshot[safari_top:safari_bottom, safari_left:safari_right]


def extract_message_text(image):
    if image is None or image.size == 0:
        return ""
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
    blurred = cv2.GaussianBlur(gray, (3, 3), 0)
    _, thresh = cv2.threshold(blurred, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
    texts = []
    for img in [gray, thresh]:
        try:
            text = pytesseract.image_to_string(img).strip()
            if text and len(text) > 3:
                texts.append(text)
        except:
            continue
    return max(texts, key=len) if texts else ""


def find_message_line(text):
    if not text:
        return None
    lines = []
    for line in text.split('\n'):
        line = line.strip()
        if len(line) < 5:
            continue
        skip = ['.py', '.md', 'import', 'def ', 'class ', 'return', 'print(',
                'instagram', 'bot', 'python', 'ollama', 'vscode', 'explorer', 
                '_pycache_', 'venv', '>>>', 'EXPLORER']
        if any(s in line.lower() for s in skip):
            continue
        lines.append(line)
    return max(lines, key=len) if lines else None


def get_ai_response(message):
    if not message or len(message.strip()) < 3:
        return None
    prompt = f"{SYSTEM_PROMPT}\n\nUser: {message.strip()}\n\nReply:"
    try:
        resp = requests.post(OLLAMA_ENDPOINT, json={"model": OLLAMA_MODEL, "prompt": prompt, "stream": False}, timeout=30)
        resp.raise_for_status()
        return resp.json().get("response", "").strip()
    except:
        return None


def find_input_position():
    if safari_left is None:
        return None
    with mss.mss() as sct:
        screenshot = np.array(sct.grab(sct.monitors[1]))
        h, w = screenshot.shape[:2]
        input_roi_top = int(safari_top + (safari_bottom - safari_top) * 0.75)
        input_roi_bottom = min(h, safari_bottom)
        roi = screenshot[input_roi_top:input_roi_bottom, safari_left:safari_right]
        gray = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)
        data = pytesseract.image_to_data(gray, output_type=pytesseract.Output.DICT)
        for i, text in enumerate(data['text']):
            text_lower = text.lower().strip()
            conf = float(data['conf'][i]) if data['conf'][i] != '-1' else 0
            if conf > 30 and ('message' in text_lower or text_lower == ''):
                x = data['left'][i] + safari_left + data['width'][i] // 2
                y = data['top'][i] + input_roi_top + data['height'][i] // 2
                return (x, y)
        return ((safari_left + safari_right) // 2, safari_bottom - 40)


def send_reply(message):
    print(f"  Sending: '{message[:50]}...'")
    input_pos = find_input_position()
    if input_pos:
        pyautogui.click(input_pos[0], input_pos[1])
        human_delay(0.4, 0.6)
    else:
        pyautogui.click((safari_left + safari_right) // 2, safari_bottom - 40)
        human_delay(0.4, 0.6)
    pyautogui.hotkey('cmd', 'a')
    human_delay(0.15, 0.25)
    pyautogui.press('backspace')
    human_delay(0.15, 0.25)
    type_human(message)
    human_delay(0.3, 0.5)
    pyautogui.press('enter')
    print("  ✓ Sent in Safari!")
    return True


def run_bot():
    print("=" * 60)
    print("INSTAGRAM DM BOT - SAFARI AUTO")
    print("=" * 60)
    setup_safari_position()
    print("Watching for messages... Press Ctrl+C to stop.\n")
    last_text = None
    reply_count = 0
    try:
        while True:
            image = capture_safari()
            text = extract_message_text(image)
            if text and text != last_text:
                message = find_message_line(text)
                if message:
                    print(f"[{reply_count + 1}] '{message[:60]}...'")
                    reply = get_ai_response(message)
                    if reply:
                        print(f"  AI: '{reply[:50]}...'")
                        send_reply(reply)
                        reply_count += 1
                last_text = text
            time.sleep(CHECK_INTERVAL)
    except KeyboardInterrupt:
        print(f"\n✓ Bot stopped. Sent {reply_count} replies.")


if __name__ == "__main__":
    run_bot()
