<parameter name="content">#!/usr/bin/env python3
"""
Instagram DM Bot - Single file, works with Safari
"""

import pyautogui
import time
import random
import cv2
import numpy as np
import mss
import pytesseract
import requests


OLLAMA_ENDPOINT = "http://localhost:11434/api/generate"
OLLAMA_MODEL = "mistral"
SYSTEM_PROMPT = """You are a friendly Instagram DM assistant. Reply briefly (under 150 chars)."""
CHECK_INTERVAL = 3

safari_left = safari_top = safari_right = safari_bottom = None
last_text = None


def human_delay(min_s=0.3, max_s=0.8):
    time.sleep(random.uniform(min_s, max_s))


def type_human(text):
    for char in text:
        if len(char) == 1 and char.isalnum():
            pyautogui.press(char)
        else:
            pyautogui.write(char)
        time.sleep(random.uniform(0.03, 0.07))


def setup_safari():
    """Click Safari to set position, auto-starts after click."""
    global safari_left, safari_top, safari_right, safari_bottom
    
    print("\n=== INSTAGRAM DM BOT ===")
    print("1. Open Instagram DM in Safari")
    print("2. Click somewhere INSIDE the Safari window")
    print("   Bot will start automatically after your click\n")
    
    last_pos = pyautogui.position()
    while True:
        current_pos = pyautogui.position()
        if current_pos != last_pos:
            sx, sy = current_pos[0], current_pos[1]
            print(f"   Clicked at: ({sx}, {sy})")
            
            safari_left = max(0, sx - 400)
            safari_top = max(0, sy - 250)
            safari_right = min(1920, sx + 400)
            safari_bottom = min(1080, sy + 250)
            
            print(f"✓ Watching area: ({safari_left}, {safari_top}) to ({safari_right}, {safari_bottom})")
            print("✓ Bot started! Watching for messages...\n")
            break
        last_pos = current_pos
        time.sleep(0.1)


def capture_chat():
    """Capture only Safari chat region."""
    if safari_left is None:
        return None
    with mss.mss() as sct:
        screenshot = np.array(sct.grab(sct.monitors[1]))
        return screenshot[safari_top:safari_bottom, safari_left:safari_right]


def read_message(image):
    """Extract message from image using OCR."""
    if image is None or image.size == 0:
        return ""
    
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
    blurred = cv2.GaussianBlur(gray, (3, 3), 0)
    _, thresh = cv2.threshold(blurred, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
    
    texts = []
    for img in [gray, thresh]:
        try:
            text = pytesseract.image_to_string(img).strip()
            if text and len(text) > 5:
                texts.append(text)
        except:
            continue
    
    return max(texts, key=len) if texts else ""


def clean_message(text):
    """Filter out VS Code and other noise."""
    if not text:
        return None
    
    skip = ['.py', '.md', 'import', 'def ', 'class ', 'return', 'print(',
            'instagram', 'bot', 'python', 'ollama', 'vscode', 'explorer', 
            '_pycache_', 'venv', '>>>', 'EXPLORER', 'BOT_STATUS', 'TODO']
    
    lines = []
    for line in text.split('\n'):
        line = line.strip()
        if len(line) < 5:
            continue
        if any(s in line.lower() for s in skip):
            continue
        lines.append(line)
    
    return max(lines, key=len) if lines else None


def get_ai_reply(message):
    """Get AI response from Ollama."""
    if not message or len(message.strip()) < 3:
        return None
    
    prompt = f"{SYSTEM_PROMPT}\n\nUser: {message.strip()}\n\nReply:"
    
    try:
        resp = requests.post(OLLAMA_ENDPOINT, json={"model": OLLAMA_MODEL, "prompt": prompt, "stream": False}, timeout=30)
        resp.raise_for_status()
        reply = resp.json().get("response", "").strip()
        return reply if reply and len(reply) > 2 else None
    except Exception as e:
        print(f"  AI error: {e}")
        return None


def find_input():
    """Find message input in Safari only."""
    if safari_left is None:
        return None
    
    with mss.mss() as sct:
        screenshot = np.array(sct.grab(sct.monitors[1]))
        h, w = screenshot.shape[:2]
        
        # Look at bottom of Safari area
        roi_top = int(safari_top + (safari_bottom - safari_top) * 0.75)
        roi = screenshot[roi_top:safari_bottom, safari_left:safari_right]
        gray = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)
        
        data = pytesseract.image_to_data(gray, output_type=pytesseract.Output.DICT)
        
        for i, text in enumerate(data['text']):
            text_lower = text.lower().strip()
            conf = float(data['conf'][i]) if data['conf'][i] != '-1' else 0
            
            if conf > 25 and ('message' in text_lower or text_lower == ''):
                x = data['left'][i] + safari_left + data['width'][i] // 2
                y = data['top'][i] + roi_top + data['height'][i] // 2
                return (x, y)
        
        # Fallback to bottom center of Safari
        return ((safari_left + safari_right) // 2, safari_bottom - 40)


def send_reply(message):
    """Send reply ONLY in Safari."""
    print(f"  Sending: '{message[:50]}...'")
    
    input_pos = find_input()
    if input_pos:
        pyautogui.click(input_pos[0], input_pos[1])
    else:
        pyautogui.click((safari_left + safari_right) // 2, safari_bottom - 40)
    
    human_delay(0.4, 0.6)
    pyautogui.hotkey('cmd', 'a')
    human_delay(0.15, 0.25)
    pyautogui.press('backspace')
    human_delay(0.15, 0.25)
    type_human(message)
    human_delay(0.3, 0.5)
    pyautogui.press('enter')
    print("  ✓ Sent in Safari!")
    return True


def run():
    """Main loop."""
    setup_safari()
    
    reply_count = 0
    try:
        while True:
            image = capture_chat()
            text = read_message(image)
            
            if text and text != last_text:
                message = clean_message(text)
                if message:
                    print(f"[{reply_count + 1}] '{message[:60]}...'")
                    reply = get_ai_reply(message)
                    if reply:
                        print(f"  AI: '{reply[:50]}...'")
                        send_reply(reply)
                        reply_count += 1
                last_text = text
            
            time.sleep(CHECK_INTERVAL)
            
    except KeyboardInterrupt:
        print(f"\n✓ Stopped. Sent {reply_count} replies.")


if __name__ == "__main__":
    run()
